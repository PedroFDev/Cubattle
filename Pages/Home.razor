@page "/"
@layout GameLayout
@implements IDisposable
@inject IJSRuntime JS
@using System.Threading
@using System.Globalization

<div class="cubattle">

@if (_phase == Phase.Home)
{
    <div class="home">
        <h1 class="title">CUBATTLE</h1>
        <p class="home-sub">Aposte em qual quadrado vai vencer a batalha!</p>

        <div class="bet-cards">
            <button class="bet-card bet-blue @(_bet == 1 ? "bet-selected" : "")" @onclick="@(() => _bet = 1)">
                <div class="bet-sq sq-1-game">@_hp1</div>
                <h2>Quadrado 1</h2>
                <p class="vuln">Vulnerável: ↑ topo e ↓ base</p>
                <span class="bet-badge">@(_bet == 1 ? "✔ Sua aposta" : "Apostar")</span>
            </button>

            <span class="bet-vs">VS</span>

            <button class="bet-card bet-red @(_bet == 2 ? "bet-selected" : "")" @onclick="@(() => _bet = 2)">
                <div class="bet-sq sq-2-game">@_hp2</div>
                <h2>Quadrado 2</h2>
                <p class="vuln">Vulnerável: ← esquerda e → direita</p>
                <span class="bet-badge">@(_bet == 2 ? "✔ Sua aposta" : "Apostar")</span>
            </button>
        </div>

        <div class="home-actions">
            <button class="btn-start" @onclick="StartGame">▶ Jogar</button>
            <button class="btn-config" @onclick="@(() => _phase = Phase.Config)">⚙ Configurações</button>
        </div>
    </div>
}
else if (_phase == Phase.Config)
{
    <div class="setup">
        <h1 class="title">Configurações</h1>

        <div class="config-row">
            <span class="config-label">Arena:</span>
            <select class="combo" value="@ArenaKey" @onchange="OnArenaSelect">
                @foreach (var p in _arenaPresets)
                {
                    <option value="@($"{p.w}x{p.h}")">@p.label (@p.w×@p.h)</option>
                }
                <option value="custom" disabled hidden>Personalizado (@_arenaW×@_arenaH)</option>
            </select>

            <span class="config-sep">|</span>

            <span class="config-label">Velocidade:</span>
            <select class="combo" value="@_speedMult.ToString(CultureInfo.InvariantCulture)" @onchange="OnSpeedChange">
                <option value="0.25">0.25×</option>
                <option value="0.5">0.50×</option>
                <option value="1">1×</option>
                <option value="1.5">1.5×</option>
                <option value="2">2×</option>
            </select>

            <span class="config-sep">|</span>

            <button class="btn-reset" @onclick="ResetAll">↺ Resetar</button>
        </div>

        <div class="place-controls">
            <span class="config-label">Posicionar:</span>
            <button class="@PlaceBtn(1)" @onclick="@(() => { _placing = 1; })">● Quadrado 1</button>
            <button class="@PlaceBtn(2)" @onclick="@(() => { _placing = 2; })">● Quadrado 2</button>
            <span class="place-hint">→ clique na arena para posicionar</span>
        </div>

        <div class="arena-preview" @ref="_previewEl"
             style="width:min(100%, @Px(PreviewW)); aspect-ratio:@_arenaW / @_arenaH;" @onclick="OnPreviewClick">
            <div class="prev-sq prev-blue @(_placing == 1 ? "prev-active" : "")"
                 style="left:@Pct(_startX1, _arenaW); top:@Pct(_startY1, _arenaH); width:@Pct(InitSize1, _arenaW); height:@Pct(InitSize1, _arenaH);">
                @_hp1
            </div>
            <div class="prev-sq prev-red @(_placing == 2 ? "prev-active" : "")"
                 style="left:@Pct(_startX2, _arenaW); top:@Pct(_startY2, _arenaH); width:@Pct(InitSize2, _arenaW); height:@Pct(InitSize2, _arenaH);">
                @_hp2
            </div>

            <div class="resize-handle resize-e"  @onpointerdown="e => StartResize(e, ResizeDir.E)"
                 @onpointerdown:stopPropagation="true" @onclick:stopPropagation="true"></div>
            <div class="resize-handle resize-s"  @onpointerdown="e => StartResize(e, ResizeDir.S)"
                 @onpointerdown:stopPropagation="true" @onclick:stopPropagation="true"></div>
            <div class="resize-handle resize-se" @onpointerdown="e => StartResize(e, ResizeDir.SE)"
                 @onpointerdown:stopPropagation="true" @onclick:stopPropagation="true"></div>
        </div>

        @if (_resizing != ResizeDir.None)
        {
            <div class="resize-overlay" @onpointermove="OnResizeMove"
                 @onpointerup="EndResize" @onpointerleave="EndResize"></div>
        }

        <div class="panels">

            <div class="panel panel-blue">
                <div class="sq-demo sq-blue-fill"></div>
                <h2>Quadrado 1</h2>
                <p class="vuln">Vulnerável: ↑ topo e ↓ base</p>
                <div class="hp-row">
                    <span class="hp-label">Vida: <strong>@_hp1</strong></span>
                    <input type="range" min="1" max="8" step="1" @bind="_hp1" @bind:event="oninput" @bind:after="ClampPositions" />
                </div>
                <div class="dir-grid">
                    <button class="@Sel(_dir1, Dir.NW)" @onclick="@(() => { _dir1 = Dir.NW; })">↖</button>
                    <button class="@Sel(_dir1, Dir.N)"  @onclick="@(() => { _dir1 = Dir.N;  })">↑</button>
                    <button class="@Sel(_dir1, Dir.NE)" @onclick="@(() => { _dir1 = Dir.NE; })">↗</button>
                    <button class="@Sel(_dir1, Dir.W)"  @onclick="@(() => { _dir1 = Dir.W;  })">←</button>
                    <span class="dir-center">●</span>
                    <button class="@Sel(_dir1, Dir.E)"  @onclick="@(() => { _dir1 = Dir.E;  })">→</button>
                    <button class="@Sel(_dir1, Dir.SW)" @onclick="@(() => { _dir1 = Dir.SW; })">↙</button>
                    <button class="@Sel(_dir1, Dir.S)"  @onclick="@(() => { _dir1 = Dir.S;  })">↓</button>
                    <button class="@Sel(_dir1, Dir.SE)" @onclick="@(() => { _dir1 = Dir.SE; })">↘</button>
                </div>
            </div>

            <div class="panel panel-red">
                <div class="sq-demo sq-red-fill"></div>
                <h2>Quadrado 2</h2>
                <p class="vuln">Vulnerável: ← esquerda e → direita</p>
                <div class="hp-row">
                    <span class="hp-label">Vida: <strong>@_hp2</strong></span>
                    <input type="range" min="1" max="8" step="1" @bind="_hp2" @bind:event="oninput" @bind:after="ClampPositions" />
                </div>
                <div class="dir-grid">
                    <button class="@Sel(_dir2, Dir.NW)" @onclick="@(() => { _dir2 = Dir.NW; })">↖</button>
                    <button class="@Sel(_dir2, Dir.N)"  @onclick="@(() => { _dir2 = Dir.N;  })">↑</button>
                    <button class="@Sel(_dir2, Dir.NE)" @onclick="@(() => { _dir2 = Dir.NE; })">↗</button>
                    <button class="@Sel(_dir2, Dir.W)"  @onclick="@(() => { _dir2 = Dir.W;  })">←</button>
                    <span class="dir-center">●</span>
                    <button class="@Sel(_dir2, Dir.E)"  @onclick="@(() => { _dir2 = Dir.E;  })">→</button>
                    <button class="@Sel(_dir2, Dir.SW)" @onclick="@(() => { _dir2 = Dir.SW; })">↙</button>
                    <button class="@Sel(_dir2, Dir.S)"  @onclick="@(() => { _dir2 = Dir.S;  })">↓</button>
                    <button class="@Sel(_dir2, Dir.SE)" @onclick="@(() => { _dir2 = Dir.SE; })">↘</button>
                </div>
            </div>

        </div>

        <div class="home-actions">
            <button class="btn-config" @onclick="@(() => _phase = Phase.Home)">← Voltar</button>
            <button class="btn-start" @onclick="StartGame">▶ Jogar</button>
        </div>
    </div>
}
else if (_phase == Phase.Playing)
{
    <div class="hud" style="width:min(100%, @Px(_arenaW));">
        <div class="hud-blue">
            <span>Quadrado 1</span>
            <span class="hearts">@Hearts(_sq1)</span>
        </div>
        <button class="btn-stop" @onclick="ResetGame">■ Parar</button>
        <div class="hud-red">
            <span class="hearts">@Hearts(_sq2)</span>
            <span>Quadrado 2</span>
        </div>
    </div>
    <div class="arena" style="width:min(100%, @Px(_arenaW)); aspect-ratio:@_arenaW / @_arenaH;">
        <div class="sq sq-1-game"
             style="left:@Pct(_sq1.X, _arenaW); top:@Pct(_sq1.Y, _arenaH); width:@Pct(_sq1.Size, _arenaW); height:@Pct(_sq1.Size, _arenaH);">
            @(_sq1.MaxHits - _sq1.HitCount)
        </div>
        <div class="sq sq-2-game"
             style="left:@Pct(_sq2.X, _arenaW); top:@Pct(_sq2.Y, _arenaH); width:@Pct(_sq2.Size, _arenaW); height:@Pct(_sq2.Size, _arenaH);">
            @(_sq2.MaxHits - _sq2.HitCount)
        </div>
    </div>
    <div class="legend">
        <span class="leg-vuln"></span> lado vulnerável
    </div>
}
else
{
    bool won = _bet == _winnerNum;
    <div class="gameover">
        <h1 class="result @(won ? "result-win" : "result-lose")">@(won ? "🎉 Você ganhou!" : "😢 Você perdeu")</h1>
        <p class="result-sub">
            Quadrado @_winnerNum venceu — você apostou no Quadrado @_bet.
        </p>
        <button class="btn-start" @onclick="@(() => _phase = Phase.Home)">↩ Voltar ao início</button>
    </div>
}

</div>

@code {
    // ── Constantes ─────────────────────────────────────────────
    const double HitShrink = 15, MinSize = 20, BaseStep = 4.0;
    const int    SizePerHP = 15, CooldownFrames = 25;
    const double PreviewScale = 0.4;   // escala fixa: preview cresce/encolhe junto com a arena
    const int    MinArenaW = 400, MaxArenaW = 1400, MinArenaH = 300, MaxArenaH = 800;

    // Padrões (usados no botão Resetar)
    const int    DefArenaW = 800, DefArenaH = 500, DefHp = 4;
    const double DefSpeed  = 1.0;

    // ── Tipos ──────────────────────────────────────────────────
    enum Phase     { Home, Config, Playing, GameOver }
    enum Dir       { NW, N, NE, W, E, SW, S, SE }
    enum ResizeDir { None, E, S, SE }

    // Presets de tamanho da arena (combobox)
    readonly (string label, int w, int h)[] _arenaPresets =
    {
        ("Pequena", 600, 400),
        ("Média",   800, 500),
        ("Grande", 1000, 600),
        ("Ampla",  1200, 650),
        ("Enorme", 1400, 800),
    };

    class Sq
    {
        public double X, Y, Size, VX, VY;
        public int    HitCount, MaxHits;
        public double Right  => X + Size;
        public double Bottom => Y + Size;
        public double CX     => X + Size / 2;
        public double CY     => Y + Size / 2;
    }

    // ── Configuração ───────────────────────────────────────────
    int    _arenaW = 800, _arenaH = 500;
    int    _hp1 = 4, _hp2 = 4;
    double _speedMult = 1.0;   // multiplicador visual (0.25× a 4×)
    Dir    _dir1 = Dir.NE, _dir2 = Dir.SW;
    int    _placing = 1;
    double _startX1, _startY1, _startX2, _startY2;
    int    _bet = 1;           // quadrado em que o jogador apostou (1 ou 2)

    // ── Estado ─────────────────────────────────────────────────
    Phase                  _phase  = Phase.Home;
    Sq                     _sq1    = new(), _sq2 = new();
    int                    _winnerNum;   // 1 ou 2
    int                    _cooldown;
    bool                   _touching;
    CancellationTokenSource? _cts;
    ElementReference       _previewEl;

    // Estado do redimensionamento por arrasto
    ResizeDir _resizing = ResizeDir.None;
    double    _resizeStartX, _resizeStartY, _resizeScale;
    int       _resizeStartW, _resizeStartH;

    // ── Derivados ──────────────────────────────────────────────
    double InitSize1    => MinSize + _hp1 * SizePerHP;
    double InitSize2    => MinSize + _hp2 * SizePerHP;
    double PreviewW     => _arenaW * PreviewScale;
    string ArenaKey     => _arenaPresets.Any(p => p.w == _arenaW && p.h == _arenaH)
        ? $"{_arenaW}x{_arenaH}" : "custom";

    // ── Helpers ────────────────────────────────────────────────
    static string Px(double v)      => $"{v:F0}px";
    // Posição/tamanho como % da arena → escala junto com o elemento (responsivo)
    static string Pct(double v, double total)
        => (total <= 0 ? 0 : v / total * 100).ToString("F4", CultureInfo.InvariantCulture) + "%";
    static string Hearts(Sq s)      => new string('♥', Math.Max(0, s.MaxHits - s.HitCount)) + new string('♡', Math.Min(s.MaxHits, s.HitCount));
    string Sel(Dir cur, Dir btn)    => cur == btn ? "dir-btn active" : "dir-btn";
    string PlaceBtn(int i)          => _placing == i
        ? (i == 1 ? "place-btn place-btn-blue active" : "place-btn place-btn-red active")
        : "place-btn";

    // Retorna vetor unitário (magnitude = 1.0) — velocidade real é aplicada pelo BaseStep
    static (double vx, double vy) Vec(Dir d)
    {
        const double D = 0.7071;
        return d switch
        {
            Dir.N  => (0,  -1), Dir.NE => ( D, -D),
            Dir.E  => (1,   0), Dir.SE => ( D,  D),
            Dir.S  => (0,   1), Dir.SW => (-D,  D),
            Dir.W  => (-1,  0), _      => (-D, -D),
        };
    }

    // ── Ciclo de vida ──────────────────────────────────────────
    protected override void OnInitialized() => ResetPositions();

    // Reset total de posições (usado na mudança de tamanho da arena)
    void ResetPositions()
    {
        _startX1 = Math.Clamp(_arenaW * .25 - InitSize1 / 2, 0, Math.Max(0, _arenaW - InitSize1));
        _startY1 = Math.Clamp(_arenaH * .5  - InitSize1 / 2, 0, Math.Max(0, _arenaH - InitSize1));
        _startX2 = Math.Clamp(_arenaW * .75 - InitSize2 / 2, 0, Math.Max(0, _arenaW - InitSize2));
        _startY2 = Math.Clamp(_arenaH * .5  - InitSize2 / 2, 0, Math.Max(0, _arenaH - InitSize2));
    }

    // Apenas garante que posições continuam válidas ao mudar HP (mantém posição manual)
    void ClampPositions()
    {
        _startX1 = Math.Clamp(_startX1, 0, Math.Max(0, _arenaW - InitSize1));
        _startY1 = Math.Clamp(_startY1, 0, Math.Max(0, _arenaH - InitSize1));
        _startX2 = Math.Clamp(_startX2, 0, Math.Max(0, _arenaW - InitSize2));
        _startY2 = Math.Clamp(_startY2, 0, Math.Max(0, _arenaH - InitSize2));
    }

    async Task OnPreviewClick(MouseEventArgs e)
    {
        // Mede a largura renderizada do preview (pode estar reduzida em telas pequenas)
        double w = await JS.InvokeAsync<double>("cubattle.width", _previewEl);
        if (w <= 0) return;

        double scale = w / _arenaW;          // px renderizados por px de arena (uniforme)
        double ax = e.OffsetX / scale;
        double ay = e.OffsetY / scale;

        if (_placing == 1)
        {
            _startX1 = Math.Clamp(ax - InitSize1 / 2, 0, Math.Max(0, _arenaW - InitSize1));
            _startY1 = Math.Clamp(ay - InitSize1 / 2, 0, Math.Max(0, _arenaH - InitSize1));
        }
        else
        {
            _startX2 = Math.Clamp(ax - InitSize2 / 2, 0, Math.Max(0, _arenaW - InitSize2));
            _startY2 = Math.Clamp(ay - InitSize2 / 2, 0, Math.Max(0, _arenaH - InitSize2));
        }
    }

    // ── Configuração: comboboxes e reset ───────────────────────
    void OnArenaSelect(ChangeEventArgs e)
    {
        var key = (string?)e.Value;
        if (string.IsNullOrEmpty(key) || key == "custom") return;
        var parts = key.Split('x');
        _arenaW = int.Parse(parts[0]);
        _arenaH = int.Parse(parts[1]);
        ResetPositions();
    }

    void OnSpeedChange(ChangeEventArgs e)
        => _speedMult = double.Parse((string)e.Value!, CultureInfo.InvariantCulture);

    void ResetAll()
    {
        _arenaW = DefArenaW; _arenaH = DefArenaH;
        _hp1 = DefHp; _hp2 = DefHp;
        _speedMult = DefSpeed;
        _dir1 = Dir.NE; _dir2 = Dir.SW;
        _placing = 1;
        ResetPositions();
    }

    // ── Redimensionar a arena arrastando as bordas do preview ──
    async Task StartResize(PointerEventArgs e, ResizeDir dir)
    {
        _resizing     = dir;
        _resizeStartX = e.ClientX;
        _resizeStartY = e.ClientY;
        _resizeStartW = _arenaW;
        _resizeStartH = _arenaH;
        // escala real renderizada (px na tela por px de arena) — robusto em telas pequenas
        double w = await JS.InvokeAsync<double>("cubattle.width", _previewEl);
        _resizeScale = w > 0 ? w / _arenaW : PreviewScale;
    }

    void OnResizeMove(PointerEventArgs e)
    {
        if (_resizing == ResizeDir.None || _resizeScale <= 0) return;

        if (_resizing is ResizeDir.E or ResizeDir.SE)
        {
            double delta = (e.ClientX - _resizeStartX) / _resizeScale;
            _arenaW = (int)(Math.Round((_resizeStartW + delta) / 10) * 10);
            _arenaW = Math.Clamp(_arenaW, MinArenaW, MaxArenaW);
        }
        if (_resizing is ResizeDir.S or ResizeDir.SE)
        {
            double delta = (e.ClientY - _resizeStartY) / _resizeScale;
            _arenaH = (int)(Math.Round((_resizeStartH + delta) / 10) * 10);
            _arenaH = Math.Clamp(_arenaH, MinArenaH, MaxArenaH);
        }
        ClampPositions();
    }

    void EndResize() => _resizing = ResizeDir.None;

    // ── Controle ───────────────────────────────────────────────
    void StartGame()
    {
        var (vx1, vy1) = Vec(_dir1);
        var (vx2, vy2) = Vec(_dir2);
        _sq1 = new Sq { X = _startX1, Y = _startY1, Size = InitSize1, VX = vx1, VY = vy1, MaxHits = _hp1 };
        _sq2 = new Sq { X = _startX2, Y = _startY2, Size = InitSize2, VX = vx2, VY = vy2, MaxHits = _hp2 };
        _cooldown = 0;
        _touching = false;
        _phase = Phase.Playing;
        _ = GameLoop();
    }

    // "Parar" durante a partida volta ao início mantendo as configurações
    void ResetGame()
    {
        StopGame();
        _phase = Phase.Home;
    }

    // ── Loop do jogo ───────────────────────────────────────────
    // Acumulador garante que a trajetória física é idêntica em qualquer velocidade —
    // _speedMult só controla quantos passos físicos são executados por frame.
    double _accumulator;

    async Task GameLoop()
    {
        _cts = new CancellationTokenSource();
        _accumulator = 0;
        try
        {
            while (!_cts.IsCancellationRequested)
            {
                await Task.Delay(16, _cts.Token);

                _accumulator += _speedMult;
                while (_accumulator >= 1.0)
                {
                    PhysicsStep();
                    _accumulator -= 1.0;
                    if (_sq1.HitCount >= _sq1.MaxHits) { End(2); return; }
                    if (_sq2.HitCount >= _sq2.MaxHits) { End(1); return; }
                }

                StateHasChanged();
            }
        }
        catch (OperationCanceledException) { }
    }

    void PhysicsStep()
    {
        MoveStep(_sq1); MoveStep(_sq2);
        Bounce(_sq1);   Bounce(_sq2);
        Collide();
    }

    // Move um "passo físico" fixo: BaseStep px na direção do vetor unitário
    static void MoveStep(Sq s) { s.X += s.VX * BaseStep; s.Y += s.VY * BaseStep; }

    void Bounce(Sq s)
    {
        if (s.X < 0)                { s.X = 0;               s.VX =  Math.Abs(s.VX); }
        if (s.X + s.Size > _arenaW) { s.X = _arenaW - s.Size; s.VX = -Math.Abs(s.VX); }
        if (s.Y < 0)                { s.Y = 0;               s.VY =  Math.Abs(s.VY); }
        if (s.Y + s.Size > _arenaH) { s.Y = _arenaH - s.Size; s.VY = -Math.Abs(s.VY); }
    }

    void Collide()
    {
        double ox = Math.Min(_sq1.Right,  _sq2.Right)  - Math.Max(_sq1.X, _sq2.X);
        double oy = Math.Min(_sq1.Bottom, _sq2.Bottom) - Math.Max(_sq1.Y, _sq2.Y);

        if (ox <= 0 || oy <= 0)
        {
            _touching = false;
            if (_cooldown > 0) _cooldown--;
            return;
        }

        bool horzHit = ox < oy;
        bool newCollision = !_touching;
        _touching = true;

        // Separação (aplicada todo frame para evitar sobreposição persistente)
        if (horzHit)
        {
            double push = ox / 2 + 1;
            if (_sq1.CX < _sq2.CX) { _sq1.X -= push; _sq2.X += push; }
            else                    { _sq1.X += push; _sq2.X -= push; }
        }
        else
        {
            double push = oy / 2 + 1;
            if (_sq1.CY < _sq2.CY) { _sq1.Y -= push; _sq2.Y += push; }
            else                    { _sq1.Y += push; _sq2.Y -= push; }
        }

        // Troca de velocidade e dano apenas no primeiro frame do contato
        if (!newCollision) return;

        if (horzHit) (_sq1.VX, _sq2.VX) = (_sq2.VX, _sq1.VX);
        else         (_sq1.VY, _sq2.VY) = (_sq2.VY, _sq1.VY);

        // Garante que nenhum quadrado fique parado após a troca
        KeepMoving(_sq1);
        KeepMoving(_sq2);

        if (_cooldown > 0) return;
        _cooldown = CooldownFrames;
        Hit(horzHit ? _sq2 : _sq1);
    }

    // Normaliza para vetor unitário e previne velocidade zero
    static void KeepMoving(Sq s)
    {
        double mag = Math.Sqrt(s.VX * s.VX + s.VY * s.VY);
        if (mag < 0.1) { s.VX = 0.7071; s.VY = 0.7071; }
        else           { s.VX /= mag;    s.VY /= mag;    }
    }

    static void Hit(Sq s)
    {
        s.X    += HitShrink / 2;
        s.Y    += HitShrink / 2;
        s.Size -= HitShrink;
        s.HitCount++;
    }

    void End(int winnerNum)
    {
        StopGame();
        _winnerNum = winnerNum;
        _phase     = Phase.GameOver;
        StateHasChanged();
    }

    void StopGame() { _cts?.Cancel(); _cts?.Dispose(); _cts = null; }

    public void Dispose() => StopGame();
}
